# ---------------------------------------------------------------------------------------------------------------------
# BASE IMAGE — sales-team
# Contains: Python runtime, dbt-core, dbt-athena, dagster, dagster-aws, dagster-dbt, boto3.
# Does NOT contain any project code. Does NOT need Spark (queries run via Amazon Athena).
# Rebuild only when dependency versions change.
# ---------------------------------------------------------------------------------------------------------------------

FROM python:3.12-slim

# ---------------------------------------------------------------------------------------------------------------------
# SYSTEM DEPENDENCIES
# gcc and python3-dev are needed to compile some Python packages (e.g., aiohttp, pyarrow).
# Cleaned up after pip install to keep image small.
# ---------------------------------------------------------------------------------------------------------------------
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        gcc \
        python3-dev \
        libffi-dev \
        git \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------------------------------------------------
# INSTALL PYTHON PACKAGES
# dbt-core + dbt-athena: dbt framework with Athena adapter (dbt Labs maintained since late 2024)
# dagster + dagster-aws: Dagster orchestrator + AWS integrations (runs on user code pod)
# dagster-dbt: DbtCliResource for running dbt directly on the pod
# boto3: AWS SDK for Athena, S3, Glue operations
# ---------------------------------------------------------------------------------------------------------------------
RUN pip install --no-cache-dir \
    "dbt-core>=1.10,<2.0" \
    "dbt-athena>=1.10,<2.0" \
    "dagster>=1.13,<2.0" \
    "dagster-aws>=0.29,<1.0" \
    "dagster-dbt>=0.29,<1.0" \
    "boto3>=1.34,<2.0"

# ---------------------------------------------------------------------------------------------------------------------
# CLEANUP BUILD DEPENDENCIES
# Remove gcc and dev packages to reduce image size. Python packages are already compiled.
# ---------------------------------------------------------------------------------------------------------------------
RUN apt-get purge -y --auto-remove \
        gcc \
        python3-dev \
        libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------------------------------------------------
# WORKING DIRECTORY
# ---------------------------------------------------------------------------------------------------------------------
WORKDIR /app

# ---------------------------------------------------------------------------------------------------------------------
# LABELS
# ---------------------------------------------------------------------------------------------------------------------
LABEL maintainer="sales-team"
LABEL description="Base image for sales-team: dbt-athena + dagster + dagster-aws + dagster-dbt"
LABEL org.opencontainers.image.source="dbt-dagster-project/sales-team"
