# ---------------------------------------------------------------------------------------------------------------------
# CODE IMAGE — de-team
# Built FROM Base_Image — only COPYs project code (dbt, Dagster, Spark entrypoint).
# No additional packages installed → build completes in <30s, no new vulnerabilities introduced.
# CI/CD rebuilds this image on every code change (tag: git commit SHA).
# ---------------------------------------------------------------------------------------------------------------------

ARG BASE_IMAGE=de-team-base:latest
FROM ${BASE_IMAGE}

# ---------------------------------------------------------------------------------------------------------------------
# LABELS
# ---------------------------------------------------------------------------------------------------------------------
LABEL maintainer="de-team"
LABEL description="Code image for de-team: dbt project + Dagster project + Spark entrypoint"
LABEL org.opencontainers.image.source="dbt-dagster-project/de-team"

# ---------------------------------------------------------------------------------------------------------------------
# COPY PROJECT CODE
# Order: dbt_project → spark_entrypoint → dagster_project
# entryPoint for EMR spark-submit: local:///app/entrypoint.py
# --chown=hadoop:hadoop so the runtime user (EMR on EKS default) can write to
# dbt working dirs (logs/, target/) at runtime.
# ---------------------------------------------------------------------------------------------------------------------
COPY --chown=hadoop:hadoop dbt_project/ /app/dbt_project/
COPY --chown=hadoop:hadoop spark_entrypoint/entrypoint.py /app/entrypoint.py
COPY --chown=hadoop:hadoop dagster_project/ /app/dagster_project/

# Use hadoop user (matching base image — EMR on EKS default)
USER hadoop

